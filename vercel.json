{
  "rewrites": [
    { "source": "/api/chat", "destination": "/api/chat.js" },
    { "source": "/chars.js", "destination": "/public/chars.js" },
    { "source": "/chat.html", "destination": "/public/chat.html" },
    { "source": "/detail.html", "destination": "/public/detail.html" },
    { "source": "/", "destination": "/public/index.html" },
    { "source": "/(.*)", "destination": "/public/$1" }
  ]
}
